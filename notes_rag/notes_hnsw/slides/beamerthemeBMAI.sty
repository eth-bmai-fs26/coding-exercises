% ================================================================
% COLORS — Primary palette: purple, gold, white
% ================================================================

% -- Primary --
\definecolor{BMAIpurple}{RGB}{75,20,120}         % deep royal purple
\definecolor{BMAIpurpleLight}{RGB}{130,80,175}    % lighter purple
\definecolor{BMAIpurplePale}{RGB}{235,225,245}    % very light purple tint
\definecolor{BMAIgold}{RGB}{197,166,81}           % warm academic gold
\definecolor{BMAIgoldLight}{RGB}{230,215,160}     % light gold
\definecolor{BMAIgoldPale}{RGB}{252,248,235}      % very light gold tint
\definecolor{BMAIgoldDark}{RGB}{155,125,45}       % dark gold for text

% -- Neutrals --
\definecolor{BMAIdark}{RGB}{35,15,55}             % near-black purple
\definecolor{BMAIgray}{RGB}{120,120,130}          % neutral gray
\definecolor{BMAIgrayLight}{RGB}{230,230,235}     % light gray

% -- Accents (for diagrams) --
\definecolor{BMAIcoral}{RGB}{210,90,75}           % warm red accent
\definecolor{BMAIteal}{RGB}{50,160,140}           % teal accent
\definecolor{BMAIsky}{RGB}{100,170,220}           % sky blue accent
\definecolor{BMAIgreen}{RGB}{80,165,90}           % green accent
\definecolor{BMAIorange}{RGB}{230,155,50}         % orange accent

% ================================================================
% BEAMER COLOR SETTINGS
% ================================================================

\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{itemize item}[square]
\setbeamertemplate{itemize subitem}[square]
\setbeamertemplate{itemize subsubitem}[triangle]

\setbeamercolor*{author}{fg=white}
\setbeamercolor*{placeanddate}{fg=white}
\setbeamercolor*{item}{fg=BMAIgold}
\setbeamercolor*{subitem}{fg=BMAIgold!70}
\setbeamercolor*{frametitle}{fg=white,bg=BMAIpurple}
\setbeamercolor*{section in toc}{fg=BMAIdark}
\setbeamercolor*{section page}{fg=BMAIdark}
\setbeamercolor{subtitle}{fg=BMAIdark}
\setbeamercolor{title}{fg=white}
\setbeamercolor{normal text}{fg=BMAIdark}
\setbeamercolor{structure}{fg=BMAIpurple}

