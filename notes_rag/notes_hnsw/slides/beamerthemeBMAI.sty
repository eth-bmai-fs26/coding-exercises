% ================================================================
% SPACING
% ================================================================

\newcommand*{\addVerticalSpace}[1]{%
  \ifvmode\else\par\vspace{-\baselineskip}\vspace{\lineskip}\fi%
  \ifdim#1>0pt\addvspace{#1}\else\vspace{#1}\fi%
}

\newcommand*{\tinysep}{\addVerticalSpace{0.5em}}
\newcommand*{\smallsep}{\addVerticalSpace{0.75em}}
\newcommand*{\medsep}{\addVerticalSpace{1.0em}}
\newcommand*{\bigsep}{\addVerticalSpace{1.5em}}
\newcommand*{\largesep}{\addVerticalSpace{2em}}

\newcommand*{\negtinysep}{\addVerticalSpace{-0.5em}}
\newcommand*{\negsmallsep}{\addVerticalSpace{-0.75em}}
\newcommand*{\negmedsep}{\addVerticalSpace{-1.0em}}
\newcommand*{\negbigsep}{\addVerticalSpace{-1.5em}}

% ================================================================
% OVERLAY TIKZ HELPERS
% ================================================================

\newcommand{\pictureat}[4][\empty]{%
  \begin{tikzpicture}[overlay,remember picture,shift={(current page.north west)},y=-1cm]%
    \node[align=left] at (#2) {\includegraphics[#3]{#4}%
    \ifthenelse{\equal{#1}{\empty}}{}{\\[-0.75em]\tiny #1}};%
  \end{tikzpicture}%
}

\newenvironment{overlaytikzpicture}{%
  \begin{tikzpicture}[overlay,remember picture,shift={(current page.north west)},y=-1cm]%
}{
  \end{tikzpicture}%
}

% ================================================================
% BACKGROUNDS
% ================================================================

\defbeamertemplate*{background}{bmai}{}

\newcommand{\setdefaultbg}{
  \setbeamertemplate{background}[bmai]
}

\newcommand{\settitlebg}{
  \setbeamercolor*{title page header}{fg=white}
  \setbeamercolor*{title}{fg=white}
  \setbeamertemplate{background}{
    \begin{tikzpicture}
      \useasboundingbox (0,0) rectangle(\the\paperwidth,\the\paperheight);
      % Full-slide purple gradient
      \fill[BMAIpurple] (0,0) rectangle (\the\paperwidth,\the\paperheight);
      % Decorative gold accent stripe
      \fill[BMAIgold,opacity=0.9]
        (0,0.42\paperheight) rectangle (\the\paperwidth,0.44\paperheight);
      % Subtle geometric decoration
      \fill[BMAIpurpleLight,opacity=0.15]
        (0.6\paperwidth,0) -- (\the\paperwidth,0)
        -- (\the\paperwidth,0.42\paperheight) -- (0.75\paperwidth,0.42\paperheight) -- cycle;
      \fill[BMAIgold,opacity=0.08]
        (0.75\paperwidth,0) -- (\the\paperwidth,0)
        -- (\the\paperwidth,0.3\paperheight) -- cycle;
    \end{tikzpicture}
  }
}

% ================================================================
% TITLE PAGE
% ================================================================

\setbeamertemplate{title page}{
  \settitlebg
  \begin{textblock*}{\textwidth}(-0.3cm,1.0cm)
    \begin{beamercolorbox}{title page header}
      \begin{beamercolorbox}{author}
        \usebeamerfont{author}\insertauthor\\[-1.4mm]%
      \end{beamercolorbox}
      \vspace{3mm}
      \usebeamerfont{title}\usebeamercolor{title}\inserttitle\\[2mm]%
      \usebeamerfont{subtitle}{\color{BMAIgoldLight}\insertsubtitle}\\[2mm]%
    \end{beamercolorbox}%
    \begin{beamercolorbox}{placeanddate}
      \usebeamerfont{placeanddate}\insertdate%
    \end{beamercolorbox}
  \end{textblock*}
}

% ================================================================
% FRAME TEMPLATES
% ================================================================

\newcommand{\titleframe}{
  {\setbeamertemplate{footline}{}
  \settitlebg
  \frame{\maketitle}}
  \addtocounter{framenumber}{-1}
  \setdefaultbg
}

% Section divider frame
\newcommand{\sectionframe}[1][]
{{
\setbeamercolor*{frametitle}{fg=normal text.fg, bg=normal text.bg}
\begin{frame}[c]
    \usebeamerfont*{title}
    \usebeamercolor*[fg]{structure}
    \LARGE \arabic{section}. \insertsection
    {\color{BMAIgold}\hrule height 1.5pt}
    \ifthenelse{\equal{#1}{}}{}{%
      ~\\[1em]
      \usebeamerfont*{subtitle}
      \usebeamercolor*[fg]{subtitle}
      \raggedright \normalsize
      #1
    }
\end{frame}
}}

% Part divider (big centered text)
\newcommand{\partframe}[2][\empty]{
  {\setbeamertemplate{footline}{}
  \begin{frame}
    \addtocounter{framenumber}{-1}
    \vfill
    \begin{center}
      \LARGE\bfseries\boldmath\color{BMAIpurple} #2 \unboldmath
      \ifthenelse{\equal{#1}{\empty}}{}{%
        \\[2mm]
        {\color{BMAIgold}\rule{4cm}{1.5pt}}\\[4mm]
        \Large\bfseries\boldmath\color{BMAIpurple!60} #1 \unboldmath
      }
    \end{center}
    \vfill
  \end{frame}}
}

% Thanks frame
\newcommand{\thanksframe}[1]{
  {\setbeamertemplate{footline}{}
  \begin{frame}
    \addtocounter{framenumber}{-1}
    \vfill
    \begin{center}
      \LARGE\bfseries\boldmath\color{BMAIpurple} #1 \unboldmath
      \\[3mm]
      {\color{BMAIgold}\rule{5cm}{2pt}}
    \end{center}
    \vfill
  \end{frame}}
}

% ================================================================
% FRAME TITLE
% ================================================================

\setbeamertemplate{frametitle}{
  \begin{beamercolorbox}[wd=\paperwidth, ht=0.85cm, dp=0.4cm]{frametitle}
    \centerline{
      \begin{minipage}{\textwidth}
        \strut\insertframetitle\strut
      \end{minipage}
    }
  \end{beamercolorbox}
}

% ================================================================
% FOOTLINE
% ================================================================

\setbeamertemplate{footline}{
  \leavevmode%
  \hbox{%
  \begin{beamercolorbox}[wd=.5\paperwidth,ht=2.5ex,dp=3ex,left]{fg=BMAIgray,bg=white}%
    \hspace{4.5mm}{\color{BMAIgray}\insertshorttitle\ \insertshortsubtitle}%
  \end{beamercolorbox}%
  \begin{beamercolorbox}[wd=.25\paperwidth,ht=2.5ex,dp=3ex,left]{fg=BMAIgray,bg=white}%
    \centering \usebeamerfont{author in head/foot}{\color{BMAIgray}\insertshortdate}
  \end{beamercolorbox}%
  \begin{beamercolorbox}[wd=.15\paperwidth,ht=2.5ex,dp=3ex,left]{fg=BMAIgray,bg=white}%
    \centering {\color{BMAIgray}\insertshortauthor}
  \end{beamercolorbox}%
  \begin{beamercolorbox}[wd=.1\paperwidth,ht=2.5ex,dp=2ex,right]{fg=BMAIgray,bg=white}%
    \raggedleft {\color{BMAIgold}\insertframenumber}%
    \hspace*{4.5mm}
  \end{beamercolorbox}}%
  \vskip0pt%
}

% ================================================================
% BOXES (info, alert, example)
% ================================================================

% --- Info box (purple) ---
\colorlet{lboxTitleBg}{BMAIpurple}
\colorlet{lboxTitleFg}{white}
\colorlet{lboxBg}{BMAIpurplePale}

\newenvironment{lbox}[1][]{
  \ifthenelse{\equal{#1}{\empty}}{
    \begin{mdframed}[linewidth=0px,backgroundcolor=lboxBg,skipabove=0.2cm,skipbelow=0.2cm]%
  }{%
    \begin{mdframed}[linewidth=0px,backgroundcolor=lboxTitleBg,skipabove=0.2cm,skipbelow=0cm]%
     \color{lboxTitleFg}%
     #1%
    \end{mdframed}%
  \begin{mdframed}[linewidth=0px,backgroundcolor=lboxBg,skipabove=0cm,skipbelow=0.2cm]%
  }
}{%
  \end{mdframed}%
}

% --- Alert box (coral) ---
\newenvironment{alertbox}[1][]{
  \setbeamercolor*{item}{fg=BMAIcoral}
  \setbeamercolor*{subitem}{fg=BMAIcoral!80}
  \ifthenelse{\equal{#1}{\empty}}{
    \begin{mdframed}[linewidth=0px,backgroundcolor=BMAIcoral!15,skipabove=0.2cm,skipbelow=0.2cm]%
  }{%
    \begin{mdframed}[linewidth=0px,backgroundcolor=BMAIcoral!80!black,skipabove=0.2cm,skipbelow=0cm]%
     \color{white}%
     #1%
    \end{mdframed}
    \begin{mdframed}[linewidth=0px,backgroundcolor=BMAIcoral!15,skipabove=0cm,skipbelow=0.2cm]%
  }%
}{%
  \end{mdframed}%
}

% --- Key insight box (gold) ---
\newenvironment{insightbox}[1][]{
  \setbeamercolor*{item}{fg=BMAIgoldDark}
  \setbeamercolor*{subitem}{fg=BMAIgoldDark!80}
  \ifthenelse{\equal{#1}{\empty}}{
    \begin{mdframed}[linewidth=0px,backgroundcolor=BMAIgoldPale,skipabove=0.2cm,skipbelow=0.2cm]%
  }{%
    \begin{mdframed}[linewidth=0px,backgroundcolor=BMAIgoldDark,skipabove=0.2cm,skipbelow=0cm]%
     \color{white}%
     #1%
    \end{mdframed}
    \begin{mdframed}[linewidth=0px,backgroundcolor=BMAIgoldPale,skipabove=0cm,skipbelow=0.2cm]%
  }%
}{%
  \end{mdframed}%
}

% --- Example box (teal) ---
\newenvironment{exbox}[1][]{
  \setbeamercolor*{item}{fg=BMAIteal}
  \setbeamercolor*{subitem}{fg=BMAIteal!80}
  \ifthenelse{\equal{#1}{\empty}}{
    \begin{mdframed}[linewidth=0px,backgroundcolor=BMAIteal!10,skipabove=0.2cm,skipbelow=0.2cm]%
  }{%
    \begin{mdframed}[linewidth=0px,backgroundcolor=BMAIteal!80!black,skipabove=0.2cm,skipbelow=0cm]%
     \color{white}%
     #1%
    \end{mdframed}
    \begin{mdframed}[linewidth=0px,backgroundcolor=BMAIteal!10,skipabove=0cm,skipbelow=0.2cm]%
  }%
}{%
  \end{mdframed}%
}

