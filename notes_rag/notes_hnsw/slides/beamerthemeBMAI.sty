% ================================================================
% TIKZ STYLES (reusable for lecture diagrams)
% ================================================================

\tikzset{
  % Graph nodes
  graphnode/.style={
    circle, draw=BMAIpurple, fill=BMAIpurplePale,
    minimum size=6mm, inner sep=0pt,
    font=\footnotesize\bfseries
  },
  graphnode highlight/.style={
    graphnode, fill=BMAIgold!60, draw=BMAIgoldDark, line width=1.2pt
  },
  graphnode query/.style={
    graphnode, fill=BMAIcoral!40, draw=BMAIcoral, line width=1.2pt,
    star, star points=5, star point ratio=0.5, minimum size=8mm
  },
  graphnode active/.style={
    graphnode, fill=BMAIgold!40, draw=BMAIgoldDark, line width=1pt
  },
  graphnode visited/.style={
    graphnode, fill=BMAIgray!30, draw=BMAIgray
  },
  graphnode result/.style={
    graphnode, fill=BMAIteal!30, draw=BMAIteal, line width=1.2pt
  },
  % Edges
  graphedge/.style={
    draw=BMAIpurple!60, line width=0.8pt
  },
  graphedge highlight/.style={
    draw=BMAIgold, line width=1.5pt, -{Stealth[length=3mm]}
  },
  graphedge search/.style={
    draw=BMAIcoral, line width=1.5pt, dashed, -{Stealth[length=3mm]}
  },
  % Layer styling
  layerbox/.style={
    draw=BMAIpurple!30, fill=BMAIpurplePale!30,
    rounded corners=3pt, inner sep=5pt
  },
  layerlabel/.style={
    font=\footnotesize\bfseries, text=BMAIpurple
  },
  % Annotation
  annot/.style={
    font=\footnotesize, text=BMAIgray
  },
  annotbold/.style={
    font=\footnotesize\bfseries, text=BMAIpurple
  },
  % Brace
  mybrace/.style={
    decorate, decoration={brace, amplitude=5pt, raise=2pt},
    draw=BMAIpurple, line width=1pt
  },
}

